# ── Required ────────────────────────────────────────────────────────────────
# Anthropic API key — pays for the model. https://console.anthropic.com/
ANTHROPIC_API_KEY=

# From your Slack app (created from bot/app-manifest.json):
#   OAuth & Permissions → Bot User OAuth Token (xoxb-…)
SLACK_BOT_TOKEN=
#   Basic Information → Signing Secret
SLACK_SIGNING_SECRET=

# ── Strongly recommended ────────────────────────────────────────────────────
# Redis URL for conversation memory across serverless invocations
# (free tier at https://upstash.com works). Without it, thread history only
# survives warm starts.
REDIS_URL=
# Redis key prefix (default: slack-agent-bot)
# BOT_STATE_PREFIX=

# ── Identity / behavior ─────────────────────────────────────────────────────
# BOT_NAME=Slack Agent
# ORG_NAME=Acme Inc
# Model id (default: claude-sonnet-5)
# BOT_MODEL=claude-sonnet-5
# Tool-loop step cap per message (default: 15)
# MAX_STEPS=15
# Extra org-specific instructions appended to the system prompt
# SYSTEM_PROMPT_APPEND=
# Full replacement of the default persona (guardrails still apply)
# SYSTEM_PROMPT=

# ── Access control ──────────────────────────────────────────────────────────
# Unset or "*" = everyone in the workspace can use the bot (default).
# CSV of Slack user IDs = restrict to those people.
# ALLOWED_SLACK_USER_IDS=U0123456789,U0987654321

# ── Knowledge base (default tool — Google Drive) ────────────────────────────
# Google OAuth app credentials + a refresh token with drive scope.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# Optional separate grant for Drive (falls back to GOOGLE_REFRESH_TOKEN)
# GOOGLE_DRIVE_REFRESH_TOKEN=
# The shared drive (or folder) that holds your docs
# DRIVE_ID=
# Folder where new notes are saved (enables kbCreateNote)
# NOTES_FOLDER_ID=
# Display name used in tool descriptions (default: "knowledge base")
# KB_NAME=

# ── Optional tools (each enables when set) ──────────────────────────────────
# Linear issue tracking
# LINEAR_API_KEY=
# Web search via Tavily — https://tavily.com
# TAVILY_API_KEY=
# Slack message search — USER token (xoxp-) with search:read scope
# SLACK_USER_TOKEN=

# ── Ops ─────────────────────────────────────────────────────────────────────
# Bearer secret for POST /api/send (outbound messages from your automations).
# Route stays disabled until set. Generate: openssl rand -hex 32
# SEND_API_SECRET=
