{
  "display_information": {
    "name": "AI Agent",
    "description": "Two-way AI assistant for this workspace — DM it or @-mention it in any channel.",
    "background_color": "#1a1d21"
  },
  "features": {
    "bot_user": {
      "display_name": "ai-agent",
      "always_online": true
    },
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "slash_commands": [
      {
        "command": "/ask",
        "url": "https://YOUR-DEPLOYMENT.vercel.app/api/webhooks/slack",
        "description": "Ask the AI agent anything",
        "usage_hint": "[your question]",
        "should_escape": false
      },
      {
        "command": "/note",
        "url": "https://YOUR-DEPLOYMENT.vercel.app/api/webhooks/slack",
        "description": "Save a URL or text to the knowledge base",
        "usage_hint": "[url or text]",
        "should_escape": false
      },
      {
        "command": "/search",
        "url": "https://YOUR-DEPLOYMENT.vercel.app/api/webhooks/slack",
        "description": "Search across every connected source",
        "usage_hint": "[query]",
        "should_escape": false
      },
      {
        "command": "/status",
        "url": "https://YOUR-DEPLOYMENT.vercel.app/api/webhooks/slack",
        "description": "Show which services the bot is connected to",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "chat:write",
        "commands",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "reactions:read",
        "reactions:write",
        "users:read"
      ],
      "user": [
        "search:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://YOUR-DEPLOYMENT.vercel.app/api/webhooks/slack",
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim",
        "member_joined_channel"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://YOUR-DEPLOYMENT.vercel.app/api/webhooks/slack"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
